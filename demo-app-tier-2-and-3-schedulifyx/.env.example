# Your SchedulifyX API key (Tier 2+ required)
SCHEDULIFYX_API_KEY=sk_live_YOUR_API_KEY_HERE

# Server port (optional, default: 4001)
PORT=4001

# Public URL for media uploads (REQUIRED for posts with media to work!)
# SchedulifyX servers need to download your media files to publish them.
# Use a tunnel service to expose your local server:
#   ngrok:        npx ngrok http 4001 → https://xxxx.ngrok-free.app
#   cloudflared:  cloudflared tunnel --url http://localhost:4001 → https://xxxx.trycloudflare.com
# Then paste the tunnel URL here:
# PUBLIC_URL=https://xxxx.ngrok-free.app
