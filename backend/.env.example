# SchedulifyX API Configuration
# Get your API key from https://app.schedulifyx.com/api-keys
SCHEDULIFY_API_KEY=sk_live_YOUR_API_KEY_HERE

# Note: API URL defaults to https://api.schedulifyx.com (no need to set)
# SCHEDULIFY_API_URL=https://api.schedulifyx.com

# App Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
PORT=3001

# Optional: Image hosting (free tier at https://api.imgbb.com/)
# Without this, image uploads will fail - get a free key!
IMGBB_API_KEY=

# Video uploads use catbox.moe (free, no API key needed, 200MB limit)
